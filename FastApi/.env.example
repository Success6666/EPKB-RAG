APP_NAME="Enterprise Private Knowledge Base RAG"
API_PREFIX="/api/v1"

VECTOR_STORE="chroma"
CHROMA_PERSIST_DIR="./data/chroma"
MILVUS_URI="http://localhost:19530"
MILVUS_TOKEN=
MILVUS_DB_NAME="default"

EMBEDDING_PROVIDER="sentence_transformers"
SENTENCE_TRANSFORMER_MODEL="BAAI/bge-small-zh-v1.5"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
OLLAMA_GENERATION_MODEL="qwen2.5:7b"
OPENAI_API_KEY=
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

RERANK_ENABLED=true
RERANK_PROVIDER=deepseek
RERANK_MODEL=deepseek-v4-flash
RERANK_BASE_URL="https://api.deepseek.com"
RERANK_API_KEY=

RABBITMQ_URL="amqp://guest:guest@localhost:5672/%2F"
RABBITMQ_QUEUE="rag.document.ingest"
RABBITMQ_MAX_RETRIES=3

MYSQL_DSN="mysql+pymysql://rag_user:change_me_mysql@localhost:3306/rag_platform"
MYSQL_KEYWORD_FULLTEXT_ENABLED=true
MYSQL_KEYWORD_LIKE_FALLBACK_ENABLED=true
MYSQL_INGEST_INSERT_BATCH_SIZE=500
VECTOR_UPSERT_BATCH_SIZE=256
FULL_DOCUMENT_CONTEXT_ENABLED=true
FULL_DOCUMENT_CONTEXT_MAX_DOCS=2
FULL_DOCUMENT_CONTEXT_MAX_CHARS=24000
FULL_DOCUMENT_CONTEXT_MIN_SCORE=0.15

JAVA_CALLBACK_BASE_URL="http://localhost:8080"
JAVA_CALLBACK_PATH="/api/documents/internal/status"
JAVA_CALLBACK_TOKEN="change_me_internal_callback_token"
JAVA_CALLBACK_TOKEN_HEADER="X-Internal-Token"
