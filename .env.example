# 基础
TZ=Asia/Shanghai
APP_ENV=prod
SPRING_PROFILES_ACTIVE=prod

# 端口
FRONTEND_PORT=3000
SPRINGBOOT_PORT=8080
FASTAPI_BIND_HOST=127.0.0.1
FASTAPI_PORT=8000
FASTAPI_WORKERS=1
FASTAPI_TIMEOUT_KEEP_ALIVE=20
MYSQL_BIND_HOST=127.0.0.1
MYSQL_PORT=3306
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379
RABBITMQ_BIND_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_BIND_HOST=127.0.0.1
RABBITMQ_MANAGEMENT_PORT=15672
MILVUS_BIND_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_METRICS_BIND_HOST=127.0.0.1
MILVUS_METRICS_PORT=9091
CHROMA_BIND_HOST=127.0.0.1
CHROMA_PORT=8001

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=rag_platform
MYSQL_USER=rag_user
MYSQL_PASSWORD=change_me_mysql

# Redis
REDIS_PASSWORD=change_me_redis

# RabbitMQ
RABBITMQ_USER=rag_user
RABBITMQ_PASSWORD=change_me_rabbit
RABBITMQ_DOCUMENT_EXCHANGE=rag.document.exchange
RABBITMQ_DOCUMENT_ROUTING_KEY=rag.document.index
RABBITMQ_DOCUMENT_QUEUE=rag.document.ingest
RABBITMQ_DOCUMENT_DLX=rag.document.dlx
RABBITMQ_DOCUMENT_DLQ_ROUTING_KEY=rag.document.dead
RABBITMQ_DOCUMENT_DLQ=rag.document.ingest.dlq
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_MAX_RETRIES=3
RAG_INGEST_CONCURRENCY=1

# FastAPI keyword index and Java callback. Replace every change_me_* value before use.
MYSQL_DSN=mysql+aiomysql://rag_user:change_me_mysql@mysql:3306/rag_platform
JAVA_CALLBACK_BASE_URL=http://springboot:8080
JAVA_CALLBACK_TOKEN=change_me_internal_callback_token

# 向量库：milvus 或 chroma。启动 compose 时也要选择对应 profile。
VECTOR_STORE=milvus
MILVUS_METRIC_TYPE=L2
MILVUS_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_SEARCH_EF=128

# SpringBoot 应用 jar。不要提交真实产物，可在本地 .env 中改为实际 jar 路径。
SPRINGBOOT_JAR=./SpringBoot/target/app.jar
JAVA_OPTS=-Xms128m -Xmx384m -XX:+UseContainerSupport -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:InitiatingHeapOccupancyPercent=30 -XX:+UseStringDeduplication -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/urandom
SERVER_TOMCAT_THREADS_MAX=64
SERVER_TOMCAT_THREADS_MIN_SPARE=4
SERVER_TOMCAT_ACCEPT_COUNT=50
SERVER_TOMCAT_MAX_CONNECTIONS=256
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1
RAG_ASYNC_CHAT_STREAM_CORE_POOL_SIZE=2
RAG_ASYNC_CHAT_STREAM_MAX_POOL_SIZE=8
RAG_ASYNC_CHAT_STREAM_QUEUE_CAPACITY=100
MALLOC_ARENA_MAX=2
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
TOKENIZERS_PARALLELISM=false
RUNTIME_GC_ENABLED=true
RUNTIME_GC_INTERVAL_SECONDS=300
RUNTIME_MALLOC_TRIM_ENABLED=true
RUNTIME_GC_LOG_ENABLED=false
RAG_DOCUMENT_ROOT=/data/uploads

# Ollama 默认连接宿主机。Linux Docker 如无法访问 host.docker.internal，可改为宿主机网关 IP。
OLLAMA_BASE_URL=http://host.docker.internal:11434
GENERATION_PROVIDER=ollama
DEFAULT_CHAT_MODEL=qwen2.5:14b
DEFAULT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_PROVIDER=sentence_transformers
OLLAMA_GENERATION_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=bge-m3
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_EMBEDDING_TRUNCATE=NONE
NVIDIA_EMBEDDING_ENCODING_FORMAT=float
NVIDIA_EMBEDDING_BATCH_SIZE=64
NVIDIA_EMBEDDING_MAX_CONCURRENCY=2
NVIDIA_EMBEDDING_MAX_RETRIES=4
NVIDIA_EMBEDDING_RETRY_BACKOFF_SECONDS=1.0
NVIDIA_EMBEDDING_RETRY_MAX_BACKOFF_SECONDS=12.0
MYSQL_INGEST_INSERT_BATCH_SIZE=500
VECTOR_UPSERT_BATCH_SIZE=256
FULL_DOCUMENT_CONTEXT_ENABLED=true
FULL_DOCUMENT_CONTEXT_MAX_DOCS=2
FULL_DOCUMENT_CONTEXT_MAX_CHARS=24000
FULL_DOCUMENT_CONTEXT_MIN_SCORE=0.15
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

RERANK_ENABLED=true
RERANK_PROVIDER=deepseek
RERANK_MODEL=deepseek-v4-flash
RERANK_BASE_URL=https://api.deepseek.com
RERANK_API_KEY=

# Java LangChain4j fallback model route. FastAPI is still the primary RAG path.
LANGCHAIN4J_ENABLED=true
LANGCHAIN4J_PROVIDER=ollama
LANGCHAIN4J_OLLAMA_BASE_URL=http://host.docker.internal:11434
LANGCHAIN4J_OLLAMA_MODEL=qwen2.5:14b
LANGCHAIN4J_OPENAI_BASE_URL=https://api.openai.com/v1
LANGCHAIN4J_OPENAI_MODEL=gpt-4o-mini
LANGCHAIN4J_API_KEY=
LANGCHAIN4J_TIMEOUT=120s
LANGCHAIN4J_MAX_RETRIES=1

# 前端本地开发可使用。生产默认不启用 demo，也不通过前端直连 FastAPI。
VITE_API_BASE_URL=/api
VITE_DEMO_MODE=false
VITE_VECTOR_STORE=Milvus
