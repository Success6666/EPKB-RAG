# 基础
TZ=Asia/Shanghai
APP_ENV=prod
SPRING_PROFILES_ACTIVE=prod

# 端口
FRONTEND_PORT=3000
SPRINGBOOT_PORT=8080
FASTAPI_BIND_HOST=127.0.0.1
FASTAPI_PORT=8000
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
CHROMA_PORT=8001

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=rag_platform
MYSQL_USER=rag_user
MYSQL_PASSWORD=change_me_mysql

# Redis
REDIS_PASSWORD=change_me_redis

# RabbitMQ
RABBITMQ_USER=rag_user
RABBITMQ_PASSWORD=change_me_rabbit
RABBITMQ_DOCUMENT_EXCHANGE=rag.document.exchange
RABBITMQ_DOCUMENT_ROUTING_KEY=rag.document.index
RABBITMQ_DOCUMENT_QUEUE=rag.document.ingest
RABBITMQ_DOCUMENT_DLX=rag.document.dlx
RABBITMQ_DOCUMENT_DLQ_ROUTING_KEY=rag.document.dead
RABBITMQ_DOCUMENT_DLQ=rag.document.ingest.dlq
RABBITMQ_PREFETCH_COUNT=3
RABBITMQ_MAX_RETRIES=3
RAG_INGEST_CONCURRENCY=3

# FastAPI keyword index and Java callback. Replace every change_me_* value before use.
MYSQL_DSN=mysql+aiomysql://rag_user:change_me_mysql@mysql:3306/rag_platform
JAVA_CALLBACK_BASE_URL=http://springboot:8080
JAVA_CALLBACK_TOKEN=change_me_internal_callback_token

# 向量库：milvus 或 chroma。启动 compose 时也要选择对应 profile。
VECTOR_STORE=milvus

# SpringBoot 应用 jar。不要提交真实产物，可在本地 .env 中改为实际 jar 路径。
SPRINGBOOT_JAR=./SpringBoot/target/app.jar
JAVA_OPTS=-Xms512m -Xmx1024m
RAG_DOCUMENT_ROOT=/data/uploads

# Ollama 默认连接宿主机。Linux Docker 如无法访问 host.docker.internal，可改为宿主机网关 IP。
OLLAMA_BASE_URL=http://host.docker.internal:11434
GENERATION_PROVIDER=ollama
DEFAULT_CHAT_MODEL=qwen2.5:14b
DEFAULT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_PROVIDER=sentence_transformers
OLLAMA_GENERATION_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=bge-m3
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_EMBEDDING_TRUNCATE=NONE
NVIDIA_EMBEDDING_ENCODING_FORMAT=float
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

RERANK_ENABLED=true
RERANK_PROVIDER=deepseek
RERANK_MODEL=deepseek-v4-flash
RERANK_BASE_URL=https://api.deepseek.com
RERANK_API_KEY=

# Java LangChain4j fallback model route. FastAPI is still the primary RAG path.
LANGCHAIN4J_ENABLED=true
LANGCHAIN4J_PROVIDER=ollama
LANGCHAIN4J_OLLAMA_BASE_URL=http://host.docker.internal:11434
LANGCHAIN4J_OLLAMA_MODEL=qwen2.5:14b
LANGCHAIN4J_OPENAI_BASE_URL=https://api.openai.com/v1
LANGCHAIN4J_OPENAI_MODEL=gpt-4o-mini
LANGCHAIN4J_API_KEY=
LANGCHAIN4J_TIMEOUT=120s
LANGCHAIN4J_MAX_RETRIES=1

# 前端本地开发可使用。生产默认不启用 demo，也不通过前端直连 FastAPI。
VITE_API_BASE_URL=/api
VITE_DEMO_MODE=false
VITE_VECTOR_STORE=Milvus
